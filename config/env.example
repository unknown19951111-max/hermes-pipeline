# Environment

# Pipeline root
export HERMES_ROOT=${HERMES_ROOT:-/opt/hermes-pipeline}

# Working directories
export HERMES_WORK=${HERMES_WORK:-$HERMES_ROOT/work}
export HERMES_ARTIFACTS=${HERMES_ARTIFACTS:-$HERMES_ROOT/artifacts}

# RPC
export ETH_RPC_URL=${ETH_RPC_URL:-}
export ETH_RPC_BACKUP_URL=${ETH_RPC_BACKUP_URL:-}
export ETH_CHAIN_ID=${ETH_CHAIN_ID:-1}
export FORK_BLOCK_NUMBER=${FORK_BLOCK_NUMBER:-latest}

# Foundry
export FOUNDRY_PROFILE=${FOUNDRY_PROFILE:-ci}
export FOUNDRY_SRC=${FOUNDRY_SRC:-src}
export FOUNDRY_OUT=${FOUNDRY_OUT:-out}
export FOUNDRY_LIBS=${FOUNDRY_LIBS:-lib}

# Solc
export SOLC_SELECT_HOME=${SOLC_SELECT_HOME:-$HOME/.solc-select}
export SOLC_VERSION=${SOLC_VERSION:-}

# Per-tool timeouts (seconds)
export T_SLITHER=${T_SLITHER:-120}
export T_ADERYN=${T_ADERYN:-60}
export T_MEDUSA_QUICK=${T_MEDUSA_QUICK:-1200}
export T_MEDUSA_DEEP=${T_MEDUSA_DEEP:-14400}
export T_ECHIDNA=${T_ECHIDNA:-3600}
export T_HALMOS=${T_HALMOS:-1800}
export T_HEVM=${T_HEVM:-1800}

# Fuzzer settings
export MEDUSA_TEST_LIMIT=${MEDUSA_TEST_LIMIT:-1000000}
export MEDUSA_WORKERS=${MEDUSA_WORKERS:-4}
export MEDUSA_SEQUENCE_LENGTH=${MEDUSA_SEQUENCE_LENGTH:-500}
export ECHIDNA_TEST_LIMIT=${ECHIDNA_TEST_LIMIT:-500000}

# Resource limits
export MAX_WORKERS=${MAX_WORKERS:-8}
export MEM_LIMIT_MB=${MEM_LIMIT_MB:-8192}
export MAX_CONCURRENT_JOBS=${MAX_CONCURRENT_JOBS:-2}
export MAX_CONCURRENT_FUZZ=${MAX_CONCURRENT_FUZZ:-1}
export MAX_JOB_WORKSPACE_GB=${MAX_JOB_WORKSPACE_GB:-20}
export MAX_CORPUS_GB=${MAX_CORPUS_GB:-5}

# Job defaults
export JOB_TIMEOUT_S=${JOB_TIMEOUT_S:-3600}
export JOB_RETRY_MAX=${JOB_RETRY_MAX:-3}
export CIRCUIT_BREAKER_THRESHOLD=${CIRCUIT_BREAKER_THRESHOLD:-3}

# Logging
export LOG_LEVEL=${LOG_LEVEL:-INFO}
export LOG_DIR=${LOG_DIR:-$HERMES_ROOT/logs}
export LOG_MAX_MB=${LOG_MAX_MB:-100}
export LOG_KEEP=${LOG_KEEP:-10}

# Sandbox
export DOCKER_IMAGE=${DOCKER_IMAGE:-hermes-pipeline:latest}
export DOCKER_NETWORK=${DOCKER_NETWORK:-hermes-net}
export USE_SANDBOX=${USE_SANDBOX:-true}

# Eligibility gate
export PROGRAM_DATA_DIR=${PROGRAM_DATA_DIR:-$HERMES_ROOT/datasets/programs}

# Verification
export VERIFICATION_LEDGER=${VERIFICATION_LEDGER:-$HERMES_ROOT/docs/verification-ledger.md}